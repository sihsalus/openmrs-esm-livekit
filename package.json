{
  "name": "@sihsalus/esm-livekit-app",
  "version": "0.1.10",
  "license": "MPL-2.0",
  "description": "OpenMRS O3 microfrontend for LiveKit voice clinical consultations",
  "browser": "dist/openmrs-esm-livekit-app.js",
  "main": "src/index.ts",
  "source": true,
  "files": [
    "dist",
    "src",
    "translations"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "build": "rspack --mode production",
    "prepack": "corepack yarn build",
    "lint": "eslint src --ext js,jsx,ts,tsx --max-warnings 0",
    "typescript": "tsc",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:e2e:token-server": "python3 token-server/e2e_contract_test.py",
    "test:smoke:token-server": "python3 token-server/smoke_test.py",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "extract-translations": "i18next 'src/**/*.component.tsx' --config ./tools/i18next-parser.config.js"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs",
    "microfrontends",
    "livekit",
    "voice",
    "clinical"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sihsalus/openmrs-esm-livekit.git"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.82.0",
    "@carbon/react": "^1.83.0",
    "@livekit/components-react": "^2.9.0",
    "livekit-client": "^2.13.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "9.x",
    "dayjs": "1.x",
    "react": "18.x",
    "react-i18next": "16.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "tslib": "2.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@openmrs/esm-styleguide": "next",
    "@playwright/test": "^1.61.0",
    "@swc/cli": "^0.3.12",
    "@swc/core": "^1.3.68",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitest/coverage-v8": "^4.1.2",
    "browserslist-config-openmrs": "^1.0.1",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.13",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "happy-dom": "^20.0.0",
    "openmrs": "next",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.14.1",
    "rxjs": "^6.6.7",
    "semver": "^7.6.3",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "yarn@4.10.3"
}
